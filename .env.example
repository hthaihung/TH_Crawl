# ============================================
# CrawlStory Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# === Supabase Configuration ===
# Get these from your Supabase project settings: https://app.supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# === Discord Configuration ===
# Bot token from Discord Developer Portal: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token-here

# Discord Guild (Server) ID to monitor and sync channels from
# Right-click on your server icon in Discord (with Developer Mode enabled) and select "Copy ID"
DISCORD_GUILD_ID=123456789012345678

# Optional: Webhook URL for simple message sending (alternative to bot)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# === Scraper Configuration ===
# Default scraping interval in minutes (can be overridden per target in DB)
SCRAPE_INTERVAL_MINUTES=20

# Maximum number of concurrent scraping operations
MAX_CONCURRENT_SCRAPES=3

# Maximum video file size in MB (Discord limit is 25MB for non-Nitro)
VIDEO_MAX_SIZE_MB=25

# Video download timeout in seconds
VIDEO_DOWNLOAD_TIMEOUT=60

# === TikTok Scraper ===
# TikTok API base URL (default: https://www.tikwm.com/api)
TIKTOK_API_BASE_URL=https://www.tikwm.com/api

# TikTok API request timeout in seconds
TIKTOK_API_TIMEOUT=30

# Maximum retry attempts for failed requests
TIKTOK_MAX_RETRIES=3

# === VPS Configuration (Optional) ===
# Only needed if deploying to a remote VPS
VPS_HOST=your-vps-ip-or-domain
VPS_USER=deploy
VPS_SSH_KEY_PATH=~/.ssh/id_rsa

# === Logging Configuration ===
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (leave empty to log to stdout only)
LOG_FILE_PATH=logs/crawlstory.log
