# CrawlStory .gitignore

# ============================================
# Environment Variables (CRITICAL - NEVER COMMIT)
# ============================================
.env
.env.local
.env.*.local
*.env

# ============================================
# Python
# ============================================
# Virtual environments
venv/
env/
ENV/
.venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# Logs
*.log
logs/
*.log.*

# ============================================
# Next.js / Node.js (for future dashboard)
# ============================================
node_modules/
.next/
out/
.vercel/
.turbo/

# npm / yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# IDEs and Editors
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# Supabase
# ============================================
.supabase/

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
*.bak
*.backup

# ============================================
# Downloaded Videos (if stored locally)
# ============================================
downloads/
videos/
temp_videos/

# ============================================
# Docker
# ============================================
docker-compose.override.yml
.dockerignore

# ============================================
# OS Files
# ============================================
Thumbs.db
Desktop.ini
